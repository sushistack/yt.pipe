# youtube.pipeline - Environment Variables
# Copy this file to .env and fill in your values.
# docker-compose automatically loads .env from the project root.

# --- API Keys (Required) ---
# LLM provider API key (OpenAI)
YTP_LLM_API_KEY=

# Image generation API key (SiliconFlow)
YTP_IMAGEGEN_API_KEY=

# TTS provider API key (OpenAI/Google; not needed for Edge TTS)
YTP_TTS_API_KEY=

# --- API Server (Optional) ---
# REST API authentication key
YTP_API_KEY=

# --- Data Paths (Optional, defaults shown) ---
# Host path to SCP source data (mounted read-only)
# YTP_SCP_DATA_PATH=./data/raw

# Host path to project workspace
# YTP_WORKSPACE_PATH=./data/projects

# Host path to SQLite database directory
# YTP_DB_PATH=./data/db

# Host path to config file
# YTP_CONFIG_PATH=./config.yaml
